---
import { type ResumeProjectItem, resume } from "../../data/resume";
import { isSectionVisible, visibleItems } from "../../data/resume.utils";
import RichHtml from "./RichHtml.astro";
import Section from "./Section.astro";
import SectionHeading from "./SectionHeading.astro";

const section = resume.sections.projects;
const items = visibleItems(section.items as ResumeProjectItem[]);
---

{
	isSectionVisible(section) && items.length > 0 && (
		<Section id="projects" variant="cards">
			<SectionHeading>{section.title}</SectionHeading>
			<ul class="space-y-8" data-animate-stagger>
				{items.map((project) => {
					const url = project.website?.url?.trim();
					return (
						<li class="card-surface-hover">
							<h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-50">
								{url ? (
									<a
										href={url}
										target="_blank"
										rel="noopener noreferrer"
										class="link-hover text-inherit"
									>
										{project.name}
									</a>
								) : (
									project.name
								)}
							</h3>
							{project.description?.trim() && (
								<div class="mt-3">
									<RichHtml html={project.description} />
								</div>
							)}
						</li>
					);
				})}
			</ul>
		</Section>
	)
}
