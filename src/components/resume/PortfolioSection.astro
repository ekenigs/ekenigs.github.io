---
import Section from "./Section.astro";
import SectionHeading from "./SectionHeading.astro";

type GalleryImage = { src: string; alt: string };

/** Carousel preview: Tanssi uses tall full-page captures (cover); Moonbeam is wider UI (contain). */
type CarouselImageFit = "cover" | "contain";

const portfolioItems: {
	title: string;
	description: string;
	images: GalleryImage[];
	carouselImageFit: CarouselImageFit;
}[] = [
{
		title: "Tanssi dApp",
		description:
			"Welcome to the Tanssi dApp—launch sovereign, Ethereum-secured appchains in minutes. Stake TANSSI with operators or sequencers, manage your chain, and use the tooling in one place, integrated with Symbiotic for Ethereum-backed restaked security and automated validator orchestration.",
		carouselImageFit: "cover",
		images: [1, 2, 3, 4, 5].map((n) => ({
			src: `/portfolio/tanssi/tanssi_${n}.webp`,
			alt: `Tanssi dApp — screenshot ${n}`,
		})),
	},
	{
		title: "Moonbeam dApp",
		description:
			"The Moonbeam dApp dashboard helps you monitor and manage crypto in one place—token balances, staking rewards, and allocation breakdowns in real time. Moonbeam is a smart-contract platform for cross-chain connected applications, so users can interact with multiple blockchains from the same experience.",
		carouselImageFit: "contain",
		images: [1, 2, 3, 4, 5].map((n) => ({
			src: `/portfolio/mbf/mbf_${n}.webp`,
			alt: `Moonbeam dApp — screenshot ${n}`,
		})),
	},
];

const imagesJson = (images: GalleryImage[]) => JSON.stringify(images);
---

<Section id="portfolio">
	<div data-portfolio-root>
		<SectionHeading>Portfolio</SectionHeading>
		<ul class="space-y-10">
			{
				portfolioItems.map((item) => (
					<li>
						<article
							data-portfolio-item
							class="rounded-xl border border-zinc-200/90 bg-zinc-100/60 p-5 dark:border-zinc-800/80 dark:bg-zinc-900/40 sm:p-6"
							data-images={imagesJson(item.images)}
						>
							<h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-50">{item.title}</h3>
							<p class="mt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
								{item.description}
							</p>
							<div class="mt-5 flex items-stretch gap-2 sm:gap-3">
								<button
									type="button"
									data-carousel-prev
									class="flex h-12 w-12 shrink-0 self-center items-center justify-center rounded-full border border-zinc-300/90 bg-white/90 text-zinc-800 shadow-sm backdrop-blur-sm transition hover:border-emerald-600/40 hover:bg-white hover:text-emerald-800 dark:border-zinc-600/90 dark:bg-zinc-900/90 dark:text-zinc-100 dark:hover:border-emerald-500/40 dark:hover:text-emerald-300 sm:h-14 sm:w-14"
									aria-label="Previous screenshot"
								>
									<svg
										class="pointer-events-none h-7 w-7 shrink-0 sm:h-8 sm:w-8"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2.5"
										stroke-linecap="round"
										stroke-linejoin="round"
										aria-hidden="true"
									>
										<path d="M15 19l-7-7 7-7" />
									</svg>
								</button>
								<div class="min-w-0 flex-1 overflow-hidden rounded-lg border border-zinc-200/80 bg-zinc-200/30 dark:border-zinc-700/80 dark:bg-zinc-950/40">
									<div
										data-carousel-track
										class="flex snap-x snap-mandatory overflow-x-auto scroll-smooth [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
									>
										{item.images.map((img, i) => (
											<button
												type="button"
												data-open-lightbox
												data-carousel-slide
												data-image-index={i}
												class="group relative aspect-[16/10] w-full shrink-0 grow-0 basis-full snap-start overflow-hidden border-0 bg-zinc-200/50 p-0 dark:bg-zinc-900/60"
											>
												<img
													src={img.src}
													alt={img.alt}
													loading="lazy"
													decoding="async"
													class:list={[
														"h-full w-full min-h-0 min-w-0 object-top transition group-hover:opacity-95",
														item.carouselImageFit === "cover"
															? "object-cover"
															: "object-contain",
													]}
												/>
											</button>
										))}
									</div>
								</div>
								<button
									type="button"
									data-carousel-next
									class="flex h-12 w-12 shrink-0 self-center items-center justify-center rounded-full border border-zinc-300/90 bg-white/90 text-zinc-800 shadow-sm backdrop-blur-sm transition hover:border-emerald-600/40 hover:bg-white hover:text-emerald-800 dark:border-zinc-600/90 dark:bg-zinc-900/90 dark:text-zinc-100 dark:hover:border-emerald-500/40 dark:hover:text-emerald-300 sm:h-14 sm:w-14"
									aria-label="Next screenshot"
								>
									<svg
										class="pointer-events-none h-7 w-7 shrink-0 sm:h-8 sm:w-8"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2.5"
										stroke-linecap="round"
										stroke-linejoin="round"
										aria-hidden="true"
									>
										<path d="M9 5l7 7-7 7" />
									</svg>
								</button>
							</div>
						</article>
					</li>
				))
			}
		</ul>

		<div
			data-portfolio-modal
			class="fixed inset-0 z-50 hidden"
			role="dialog"
			aria-modal="true"
			aria-label="Image preview"
			aria-hidden="true"
		>
			<div
				data-modal-backdrop
				class="absolute inset-0 bg-zinc-950/85 backdrop-blur-[2px]"
				aria-hidden="true"
			/>
			<div class="pointer-events-none absolute inset-0 flex items-center justify-center p-4 pt-16 sm:p-6 sm:pt-20">
				<div class="pointer-events-auto relative flex max-h-[90dvh] w-full max-w-5xl flex-col items-center">
					<button
						type="button"
						data-modal-close
						class="absolute -top-2 right-0 z-20 flex h-10 w-10 items-center justify-center rounded-full border border-zinc-500/50 bg-zinc-900/90 text-lg leading-none text-zinc-100 shadow-lg transition hover:border-emerald-500/50 hover:text-emerald-200 sm:-right-2 sm:-top-12"
						aria-label="Close"
					>
						<span aria-hidden="true">×</span>
					</button>
					<button
						type="button"
						data-modal-prev
						class="absolute top-1/2 left-0 z-20 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-zinc-500/50 bg-zinc-900/90 text-2xl leading-none text-zinc-100 shadow-lg transition hover:border-emerald-500/50 hover:text-emerald-200 sm:-left-4 md:-left-14"
						aria-label="Previous image"
					>
						<span aria-hidden="true">‹</span>
					</button>
					<button
						type="button"
						data-modal-next
						class="absolute top-1/2 right-0 z-20 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-zinc-500/50 bg-zinc-900/90 text-2xl leading-none text-zinc-100 shadow-lg transition hover:border-emerald-500/50 hover:text-emerald-200 sm:-right-4 md:-right-14"
						aria-label="Next image"
					>
						<span aria-hidden="true">›</span>
					</button>
					<img
						data-modal-img
						alt=""
						class="max-h-[85dvh] max-w-full rounded-lg object-contain shadow-2xl ring-1 ring-zinc-700/40"
					/>
				</div>
			</div>
		</div>
	</div>
</Section>

<script>
	import "../../scripts/portfolio-section-client.ts";
</script>
