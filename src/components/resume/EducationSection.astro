---
import { resume } from '../../data/resume';
import { isSectionVisible, visibleItems } from '../../data/resume.utils';
import Section from './Section.astro';
import SectionHeading from './SectionHeading.astro';

const section = resume.sections.education;
const items = visibleItems(section.items);
---

{
	isSectionVisible(section) && items.length > 0 && (
		<Section id="education" variant="diagonal">
			<SectionHeading>{section.title}</SectionHeading>
			<ul class="space-y-8" data-animate-stagger>
				{items.map((edu) => {
					const schoolUrl = edu.website?.url?.trim();
					const title = [edu.degree, edu.area].filter(Boolean).join(' — ');
					return (
						<li class="card-surface-hover">
							<div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-baseline sm:justify-between">
								<div>
									<h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-50">
										{schoolUrl ? (
											<a
												href={schoolUrl}
												target="_blank"
												rel="noopener noreferrer"
												class="link-hover text-inherit"
											>
												{edu.school}
											</a>
										) : (
											edu.school
										)}
									</h3>
									{title && <p class="mt-1 text-zinc-700 dark:text-zinc-300">{title}</p>}
								</div>
								<div class="text-sm text-zinc-600 dark:text-zinc-400">
									<time>{edu.period}</time>
									{edu.location && (
										<>
											{' '}
											<span class="text-zinc-400 dark:text-zinc-500" aria-hidden="true">
												·
											</span>{' '}
											<span>{edu.location}</span>
										</>
									)}
								</div>
							</div>
							{edu.description?.trim() && (
								<p class="mt-4 text-sm leading-relaxed text-zinc-600 dark:text-zinc-300">{edu.description}</p>
							)}
						</li>
					);
				})}
			</ul>
		</Section>
	)
}
