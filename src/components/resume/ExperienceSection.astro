---
import { resume } from '../../data/resume';
import { isSectionVisible, visibleItems } from '../../data/resume.utils';
import RichHtml from './RichHtml.astro';
import Section from './Section.astro';
import SectionHeading from './SectionHeading.astro';

const section = resume.sections.experience;
const items = visibleItems(section.items);
---

{
	isSectionVisible(section) && items.length > 0 && (
		<Section id="experience" variant="timeline">
			<SectionHeading>{section.title}</SectionHeading>
			<ol class="relative space-y-12 border-l border-zinc-200 pl-6 dark:border-zinc-800 sm:pl-8" data-animate-stagger>
				{items.map((job) => {
					const companyUrl = job.website?.url?.trim();
					return (
						<li class="relative">
							<span
								class="absolute -left-7.5 top-2 h-3 w-3 rounded-full border-2 border-zinc-50 bg-amber-500/90 ring-4 ring-amber-200/80 dark:border-zinc-950 dark:ring-amber-500/20 sm:-left-9.5"
								aria-hidden="true"
							/>
							<div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-baseline sm:justify-between">
								<div>
									<h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-50">
										{companyUrl ? (
											<a
												href={companyUrl}
												target="_blank"
												rel="noopener noreferrer"
												class="link-hover text-inherit"
											>
												{job.company}
											</a>
										) : (
											job.company
										)}
									</h3>
									<p class="text-highlight text-base font-medium">{job.position}</p>
								</div>
								<div class="text-sm text-zinc-600 dark:text-zinc-400">
									<time>{job.period}</time>
									{job.location && (
										<>
											{' '}
											<span class="text-zinc-400 dark:text-zinc-500" aria-hidden="true">
												·
											</span>{' '}
											<span>{job.location}</span>
										</>
									)}
								</div>
							</div>
							{job.description && (
								<div class="mt-4">
									<RichHtml html={job.description} />
								</div>
							)}
						</li>
					);
				})}
			</ol>
		</Section>
	)
}
