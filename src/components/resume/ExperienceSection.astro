---
import { resume } from '../../data/resume';
import { isSectionVisible, visibleItems } from '../../data/resume.utils';
import RichHtml from './RichHtml.astro';
import Section from './Section.astro';
import SectionHeading from './SectionHeading.astro';

const section = resume.sections.experience;
const items = visibleItems(section.items);
---

{
	isSectionVisible(section) && items.length > 0 && (
		<Section id="experience">
			<SectionHeading>{section.title}</SectionHeading>
			<ol class="relative space-y-12 border-l border-zinc-200 pl-6 dark:border-zinc-800 sm:pl-8">
				{items.map((job) => {
					const companyUrl = job.website?.url?.trim();
					return (
						<li class="relative">
							<span
								class="absolute -left-7.5 top-2 h-3 w-3 rounded-full border-2 border-zinc-50 bg-emerald-500/90 ring-4 ring-emerald-200/80 dark:border-zinc-950 dark:ring-emerald-500/20 sm:-left-9.5"
								aria-hidden="true"
							/>
							<div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-baseline sm:justify-between">
								<div>
									<h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-50">
										{companyUrl ? (
											<a
												href={companyUrl}
												target="_blank"
												rel="noopener noreferrer"
												class="text-inherit underline decoration-zinc-400 underline-offset-4 transition hover:text-emerald-700 hover:decoration-emerald-600/60 dark:decoration-zinc-600 dark:hover:text-emerald-300 dark:hover:decoration-emerald-500/50"
											>
												{job.company}
											</a>
										) : (
											job.company
										)}
									</h3>
									<p class="text-base font-medium text-emerald-700 dark:text-emerald-400/90">{job.position}</p>
								</div>
								<div class="text-sm text-zinc-500">
									<time>{job.period}</time>
									{job.location && (
										<>
											{' '}
											<span class="text-zinc-400 dark:text-zinc-600" aria-hidden="true">
												·
											</span>{' '}
											<span>{job.location}</span>
										</>
									)}
								</div>
							</div>
							{job.description && (
								<div class="mt-4">
									<RichHtml html={job.description} />
								</div>
							)}
						</li>
					);
				})}
			</ol>
		</Section>
	)
}
