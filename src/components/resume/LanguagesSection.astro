---
import { resume } from '../../data/resume';
import { isSectionVisible, visibleItems } from '../../data/resume.utils';
import LevelDots from './LevelDots.astro';
import Section from './Section.astro';
import SectionHeading from './SectionHeading.astro';

const section = resume.sections.languages;
const items = visibleItems(section.items);
const languageFlags: Record<string, string> = {
	english: '🇬🇧',
	german: '🇩🇪',
	russian: '🇷🇺',
	latvian: '🇱🇻',
};
---

{
	isSectionVisible(section) && items.length > 0 && (
		<Section id="languages" variant="minimal">
			<SectionHeading>{section.title}</SectionHeading>
			<ul class="space-y-3" data-animate-stagger>
				{items.map((row) => (
					<li
						data-level-card
						class="flex min-h-12 flex-wrap items-center justify-between gap-3 rounded-lg border border-zinc-200/90 bg-white/70 px-4 py-3 transition hover:border-orange-400/40 hover:shadow-md hover:shadow-orange-500/5 dark:border-zinc-800/90 dark:bg-zinc-900/35 dark:hover:border-orange-500/30"
					>
						<span class="text-sm font-medium text-zinc-800 dark:text-zinc-200">
							<span aria-hidden="true">{languageFlags[row.language.toLowerCase()] ?? '🌐'}</span>
							{' '}
							{row.language}
						</span>
						<LevelDots level={row.level} label={row.language} />
					</li>
				))}
			</ul>
		</Section>
	)
}

<script>
	import { initLevelDotsHoverWave } from "../../scripts/skills-hover-wave";

	initLevelDotsHoverWave();
	document.addEventListener("astro:after-swap", initLevelDotsHoverWave);
</script>
