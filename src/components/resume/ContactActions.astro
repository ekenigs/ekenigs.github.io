---
type SocialProfile = {
	label: string;
	href: string;
} | null;

type ContactAction = {
	id: 'location' | 'email' | 'linkedin' | 'github';
	label: string;
	title: string;
	href: string;
	linkText: string;
	copyText: string;
};

interface Props {
	location?: string;
	email?: string;
	linkedin?: SocialProfile;
	github?: SocialProfile;
}

const {
	location: locationInput = '',
	email: emailInput = '',
	linkedin = null,
	github = null,
} = Astro.props as Props;

const location = locationInput.trim();
const email = emailInput.trim();
const locationHref = location ? `https://maps.google.com/?q=${encodeURIComponent(location)}` : '';

const contactActions: ContactAction[] = [];

if (location && locationHref) {
	contactActions.push({
		id: 'location',
		label: 'Location',
		title: location,
		href: locationHref,
		linkText: location,
		copyText: location,
	});
}

if (email) {
	contactActions.push({
		id: 'email',
		label: 'Email',
		title: email,
		href: `mailto:${email}`,
		linkText: email,
		copyText: email,
	});
}

if (linkedin) {
	contactActions.push({
		id: 'linkedin',
		label: linkedin.label,
		title: linkedin.label,
		href: linkedin.href,
		linkText: linkedin.href,
		copyText: linkedin.href,
	});
}

if (github) {
	contactActions.push({
		id: 'github',
		label: github.label,
		title: github.label,
		href: github.href,
		linkText: github.href,
		copyText: github.href,
	});
}
---

<ul class="mt-6 flex items-center gap-4 text-zinc-700 dark:text-zinc-300">
	{contactActions.map((action) => (
		<li class="group relative" data-contact-item>
			<a
				href={action.href}
				target={action.id === 'email' ? undefined : '_blank'}
				rel={action.id === 'email' ? undefined : 'noopener noreferrer'}
				class="inline-flex h-10 w-10 items-center justify-center rounded-md transition hover:bg-zinc-100 hover:text-emerald-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600 dark:hover:bg-zinc-900/70 dark:hover:text-emerald-300"
				aria-label={action.label}
				title={action.title}
			>
				{action.id === 'location' && (
					<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path d="M12 22s7-5.7 7-12a7 7 0 1 0-14 0c0 6.3 7 12 7 12z" />
						<circle cx="12" cy="10" r="2.5" />
					</svg>
				)}
				{action.id === 'email' && (
					<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<rect x="3" y="5" width="18" height="14" rx="2" />
						<path d="M4 7l8 6 8-6" />
					</svg>
				)}
				{action.id === 'linkedin' && (
					<svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
					</svg>
				)}
				{action.id === 'github' && (
					<svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
					</svg>
				)}
			</a>
			<div class="invisible pointer-events-none absolute left-1/2 top-full z-10 w-max max-w-[min(22rem,calc(100vw-2rem))] -translate-x-1/2 pt-2 opacity-0 transition group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:visible group-focus-within:pointer-events-auto group-focus-within:opacity-100">
				<div class="rounded-lg border border-zinc-200 bg-white p-2 shadow-lg dark:border-zinc-800 dark:bg-zinc-900">
					<div class="flex items-center gap-3">
						<a
							href={action.href}
							target={action.id === 'email' ? undefined : '_blank'}
							rel={action.id === 'email' ? undefined : 'noopener noreferrer'}
							class="min-w-0 max-w-[16rem] truncate rounded-md px-2 py-1 text-sm text-emerald-700 underline decoration-emerald-500/40 underline-offset-4 hover:text-emerald-800 dark:text-emerald-400 dark:hover:text-emerald-300"
							title={action.linkText}
						>
							{action.linkText}
						</a>
						<button
							type="button"
							data-copy-contact
							data-copy-value={action.copyText}
							class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-zinc-200 text-zinc-700 transition hover:bg-zinc-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600 data-[copied=true]:text-emerald-700 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800 dark:data-[copied=true]:text-emerald-300"
							aria-label="Copy value"
							title="Copy"
						>
							<svg data-copy-icon class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<rect x="9" y="9" width="11" height="11" rx="2" />
								<path d="M5 15V5a2 2 0 0 1 2-2h10" />
							</svg>
							<svg data-check-icon class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<path d="M20 6L9 17l-5-5" />
							</svg>
							<span class="sr-only">Copy value</span>
						</button>
					</div>
				</div>
			</div>
		</li>
	))}
</ul>

<script>
	function copyToClipboard(value: string): Promise<void> {
		if (navigator.clipboard?.writeText) return navigator.clipboard.writeText(value);
		const input = document.createElement('textarea');
		input.value = value;
		input.style.position = 'fixed';
		input.style.opacity = '0';
		document.body.appendChild(input);
		input.select();
		document.execCommand('copy');
		document.body.removeChild(input);
		return Promise.resolve();
	}

	function initContactCopyButtons() {
		const buttons = document.querySelectorAll<HTMLButtonElement>('[data-copy-contact]');
		buttons.forEach((button) => {
			if (button.dataset.bound === 'true') return;
			button.dataset.bound = 'true';
			button.addEventListener('click', async () => {
				const value = button.dataset.copyValue ?? '';
				if (!value) return;
				const originalTitle = button.title;
				const originalLabel = button.getAttribute('aria-label') ?? 'Copy value';
				const copyIcon = button.querySelector<SVGElement>('[data-copy-icon]');
				const checkIcon = button.querySelector<SVGElement>('[data-check-icon]');
				try {
					await copyToClipboard(value);
					button.dataset.copied = 'true';
					button.title = 'Copied';
					button.setAttribute('aria-label', 'Copied');
					copyIcon?.classList.add('hidden');
					checkIcon?.classList.remove('hidden');
				} catch {
					button.title = 'Copy failed';
					button.setAttribute('aria-label', 'Copy failed');
				}
				button.blur();
				setTimeout(() => {
					delete button.dataset.copied;
					button.title = originalTitle || 'Copy';
					button.setAttribute('aria-label', originalLabel);
					copyIcon?.classList.remove('hidden');
					checkIcon?.classList.add('hidden');
				}, 1200);
			});
		});
	}

	function initContactPopoverFocusReset() {
		const items = document.querySelectorAll<HTMLElement>('[data-contact-item]');
		items.forEach((item) => {
			if (item.dataset.bound === 'true') return;
			item.dataset.bound = 'true';
			item.addEventListener('mouseenter', () => {
				const active = document.activeElement;
				if (!(active instanceof HTMLElement)) return;
				if (!active.matches('[data-copy-contact]')) return;
				if (item.contains(active)) return;
				active.blur();
			});
		});
	}

	initContactCopyButtons();
	initContactPopoverFocusReset();
	document.addEventListener('astro:after-swap', initContactCopyButtons);
	document.addEventListener('astro:after-swap', initContactPopoverFocusReset);
</script>
