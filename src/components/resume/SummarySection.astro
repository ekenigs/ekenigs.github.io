---
import { resume } from '../../data/resume';
import RichHtml from './RichHtml.astro';
import Section from './Section.astro';
import SectionHeading from './SectionHeading.astro';

const { summary } = resume;
---

{
	summary.hidden !== true && (
		<Section id="summary" variant="warm">
			<SectionHeading>{summary.title}</SectionHeading>
			<div data-animate-summary>
				<RichHtml html={summary.content} />
			</div>
		</Section>
	)
}
