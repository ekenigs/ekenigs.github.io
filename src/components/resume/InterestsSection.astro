---
import { resume } from '../../data/resume';
import { isSectionVisible, visibleItems } from '../../data/resume.utils';
import Section from './Section.astro';
import SectionHeading from './SectionHeading.astro';

const section = resume.sections.interests;
const items = visibleItems(section.items);
---

{
	isSectionVisible(section) && items.length > 0 && (
		<Section id="interests">
			<SectionHeading>{section.title}</SectionHeading>
			<ul class="flex flex-wrap gap-2">
				{items.map((item) => (
					<li>
						<span class="inline-flex items-center rounded-full border border-zinc-200 bg-zinc-100/80 px-3 py-1.5 text-sm text-zinc-700 dark:border-zinc-800 dark:bg-zinc-900/50 dark:text-zinc-300">
							{item.name}
						</span>
					</li>
				))}
			</ul>
		</Section>
	)
}
