---
import { Picture } from 'astro:assets';
import { resume } from '../../data/resume';
import { visibleItems } from '../../data/resume.utils';
import ContactActions from './ContactActions.astro';
import profilePhoto320 from '../../assets/profile/photo-320.jpg';

const { picture, basics } = resume;
const showPicture = picture.hidden !== true && Boolean(picture.url?.trim());
const profileUrl = picture.url?.trim() ?? '';
const isLocalProfilePhoto = profileUrl.startsWith('/profile/');
const profileLinks = visibleItems(resume.sections.profiles.items).flatMap((item) => {
	const href = item.website?.url?.trim();
	if (!href) return [];
	return [
		{
			href,
			label: item.network || item.username || href,
			icon: (item.icon || item.network || '').toLowerCase(),
		},
	];
});

const githubProfile =
	profileLinks.find((link) => link.icon.includes('github') || link.label.toLowerCase().includes('github')) ?? null;
const linkedinProfile =
	profileLinks.find((link) => link.icon.includes('linkedin') || link.label.toLowerCase().includes('linkedin')) ?? null;

const profileImgClass =
	'h-32 w-32 shrink-0 rounded-full object-cover ring-1 ring-zinc-300 shadow-xl shadow-zinc-900/10 dark:ring-zinc-700 dark:shadow-black/40 sm:h-40 sm:w-40';
---

<header class="relative overflow-hidden">
	<div
		class="pointer-events-none absolute inset-0 opacity-25 bg-size-[48px_48px] [background-image:linear-gradient(to_right,rgb(161_161_170/0.45)_1px,transparent_1px),linear-gradient(to_bottom,rgb(161_161_170/0.45)_1px,transparent_1px)] dark:opacity-35 dark:[background-image:linear-gradient(to_right,rgb(63_63_70/0.45)_1px,transparent_1px),linear-gradient(to_bottom,rgb(63_63_70/0.45)_1px,transparent_1px)]"
		aria-hidden="true"
	>
	</div>
	<div
		class="relative mx-auto flex w-full max-w-3xl flex-col gap-6 px-4 py-10 sm:px-6 sm:py-12 lg:flex-row lg:items-start lg:gap-8 lg:px-8 lg:py-14"
	>
		{
			showPicture && isLocalProfilePhoto && (
				<Picture
					src={profilePhoto320}
					alt={`Portrait of ${basics.name}`}
					formats={['avif', 'webp']}
					width={160}
					height={160}
					widths={[256, 320]}
					sizes="(max-width: 639px) 128px, 160px"
					loading="eager"
					decoding="async"
					fetchpriority="high"
					class={profileImgClass}
				/>
			)
		}
		{
			showPicture && !isLocalProfilePhoto && profileUrl && (
				<img
					src={profileUrl}
					width={160}
					height={160}
					alt={`Portrait of ${basics.name}`}
					class={profileImgClass}
					loading="eager"
					decoding="async"
					fetchpriority="high"
				/>
			)
		}
		<div class="min-w-0 flex-1">
			<h1 class="font-display text-3xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-4xl lg:text-5xl">
				{basics.name}
			</h1>
			<p class="mt-3 text-lg font-medium text-emerald-700 dark:text-emerald-400 sm:text-xl">{basics.headline}</p>
			<ContactActions
				location={basics.location}
				email={basics.email}
				linkedin={linkedinProfile}
				github={githubProfile}
			/>
		</div>
	</div>
</header>
