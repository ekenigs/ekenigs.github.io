---
interface Props {
	html: string;
	class?: string;
}

const { html, class: className = '' } = Astro.props;
---

<div
	class:list={[
		'rich-html text-sm leading-relaxed text-zinc-600 sm:text-base dark:text-zinc-300',
		'[&_p]:mb-4 [&_p:last-child]:mb-0',
		'[&_ul]:list-disc [&_ul]:pl-5 [&_ul]:mb-4 [&_li]:mb-2',
		'[&_a]:text-emerald-700 [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-emerald-900 dark:[&_a]:text-emerald-400 dark:hover:[&_a]:text-emerald-300',
		'[&_strong]:text-zinc-900 dark:[&_strong]:text-zinc-200',
		className,
	]}
	set:html={html}
/>
