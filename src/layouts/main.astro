---
import ThemeToggle from '../components/ThemeToggle.astro';
import '../styles/global.css';

type LayoutProps = {
	title?: string;
	description?: string;
	content?: { title?: string };
};

const { title: titleProp, description, content } = Astro.props as LayoutProps;

const pageTitle = titleProp ?? content?.title ?? 'Elmar Kenigs';
const metaDescription = description?.trim() ?? '';
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Apply saved theme before paint to avoid flash; default is dark when unset. -->
		<script is:inline>
			(function () {
				try {
					var k = "theme";
					var s = localStorage.getItem(k);
					if (s === "light") document.documentElement.classList.remove("dark");
					else document.documentElement.classList.add("dark");
				} catch (e) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
		<meta charset="utf-8" />
		<meta name="color-scheme" content="dark light" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		{metaDescription && <meta name="description" content={metaDescription} />}
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{pageTitle}</title>
	</head>
	<body class="min-h-dvh">
		<ThemeToggle />
		<slot />
	</body>
</html>
