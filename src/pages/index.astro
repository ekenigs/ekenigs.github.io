---
import EducationSection from '../components/resume/EducationSection.astro';
import ExperienceSection from '../components/resume/ExperienceSection.astro';
import InterestsSection from '../components/resume/InterestsSection.astro';
import LanguagesSection from '../components/resume/LanguagesSection.astro';
import PortfolioSection from '../components/resume/PortfolioSection.astro';
import ProfileHero from '../components/resume/ProfileHero.astro';
import ProjectsSection from '../components/resume/ProjectsSection.astro';
import SkillsSection from '../components/resume/SkillsSection.astro';
import SummarySection from '../components/resume/SummarySection.astro';
import { resume } from '../data/resume';
import { stripHtml } from '../data/resume.utils';
import MainLayout from '../layouts/main.astro';

const pageTitle = `${resume.basics.name} — ${resume.basics.headline}`;
const metaDescription = stripHtml(resume.summary.content).slice(0, 160);

const ogImageUrl = Astro.site ? new URL('/profile_picture.webp', Astro.site).href : undefined;

const profileLinks = resume.sections.profiles.items
	.filter((p) => !p.hidden && p.website?.url)
	.map((p) => p.website.url as string);

const jsonLd: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: resume.basics.name,
	url: Astro.site ? new URL('/', Astro.site).href : undefined,
	jobTitle: resume.basics.headline,
	...(ogImageUrl ? { image: ogImageUrl } : {}),
	...(resume.basics.email ? { email: resume.basics.email } : {}),
	...(profileLinks.length > 0 ? { sameAs: profileLinks } : {}),
};
---

<MainLayout title={pageTitle} description={metaDescription} ogImageUrl={ogImageUrl} jsonLd={jsonLd}>
	<main>
		<ProfileHero />
		<SummarySection />
		<ExperienceSection />
		<EducationSection />
		<ProjectsSection />
		<SkillsSection />
		<PortfolioSection />
		<LanguagesSection />
		<InterestsSection />
	</main>
	<footer class="py-10 text-center text-sm text-zinc-600 dark:text-zinc-400">
		<p>
			© {new Date().getFullYear()} {resume.basics.name}. Built with Astro & Tailwind CSS.
		</p>
	</footer>
</MainLayout>
